<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Streamer Policy Comparison · Old vs New</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: #0a0c14;
            background-image: radial-gradient(circle at 25% 20%, rgba(74,144,196,0.07) 0%, transparent 55%),
                              radial-gradient(circle at 75% 20%, rgba(232,131,58,0.07) 0%, transparent 55%);
            min-height: 100vh;
            display: flex; align-items: center; justify-content: center;
            font-family: 'Inter', 'PingFang SC', system-ui, sans-serif;
            padding: 20px; color: #fff;
        }
        .container { width: 100%; max-width: 1300px; display: flex; flex-direction: column; gap: 20px; }
        .header { text-align: center; }
        .header .badge {
            display: inline-block; background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.12); border-radius: 40px;
            padding: 5px 22px; font-size: 0.75rem; letter-spacing: 2px; color: #aaa; margin-bottom: 8px;
        }
        .header h1 {
            font-size: clamp(1.8rem, 3.5vw, 2.4rem); font-weight: 800;
            background: linear-gradient(to bottom, #ffffff 30%, #c0b080);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .revenue-selector {
            display: flex; align-items: center; justify-content: center; gap: 15px; flex-wrap: wrap;
            background: rgba(255,255,255,0.015); border: 1px solid rgba(255,255,255,0.08);
            border-radius: 50px; padding: 12px 30px; backdrop-filter: blur(15px); margin: 0 auto;
        }
        .revenue-selector label { font-weight: 600; font-size: 0.9rem; letter-spacing: 1px; color: #c0c0d0; }
        .revenue-amount { font-size: 2.2rem; font-weight: 900; color: #ffd966; text-shadow: 0 0 25px rgba(255,200,0,0.4); min-width: 90px; text-align: center; }
        .revenue-unit { font-size: 0.9rem; color: #b0a070; }
        .revenue-slider {
            -webkit-appearance: none; width: 260px; height: 6px;
            background: linear-gradient(to right, #5b9bd5, #e8833a); border-radius: 5px; outline: none;
        }
        .revenue-slider::-webkit-slider-thumb {
            -webkit-appearance: none; width: 22px; height: 22px; background: white;
            border-radius: 50%; box-shadow: 0 0 20px rgba(255,255,255,0.7); cursor: pointer;
        }
        .stage {
            position: relative; background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.07);
            border-radius: 32px; overflow: hidden; backdrop-filter: blur(20px);
            box-shadow: 0 30px 80px rgba(0,0,0,0.7); min-height: 460px;
        }
        .stage canvas { display: block; width: 100%; height: auto; pointer-events: none; }
        .overlay {
            position: absolute; top: 0; left: 0; right: 0; bottom: 0; pointer-events: none;
            display: flex; flex-direction: column; align-items: center; justify-content: space-between;
            padding: 20px 25px 15px; z-index: 10;
        }
        .cards-row { display: flex; gap: 20px; width: 100%; justify-content: center; flex-wrap: wrap; margin-bottom: 6px; }
        .policy-card {
            flex: 1; min-width: 270px; max-width: 440px; background: rgba(15,15,30,0.8);
            backdrop-filter: blur(25px); border-radius: 24px; padding: 20px 18px;
            display: flex; flex-direction: column; gap: 10px; border: 1px solid rgba(255,255,255,0.1);
            transition: box-shadow 0.4s; pointer-events: auto;
        }
        .policy-card.left { border-left: 3px solid #4a90c4; }
        .policy-card.right { border-left: 3px solid #e8833a; }
        .policy-title { font-weight: 800; font-size: 1rem; letter-spacing: 1px; display: flex; align-items: center; gap: 6px; }
        .left .policy-title { color: #7ab0e0; } .right .policy-title { color: #f0a070; }
        .tier-badge {
            background: rgba(255,255,255,0.07); border-radius: 20px; padding: 4px 14px;
            font-size: 0.8rem; font-weight: 700; display: inline-block; align-self: flex-start;
        }
        .left .tier-badge { color: #add8ff; } .right .tier-badge { color: #ffbd8a; }
        .no-tier { color: #ff8888 !important; background: rgba(255,80,80,0.15); }
        .info-row {
            display: flex; justify-content: space-between; font-size: 0.85rem; color: #bbb;
            border-bottom: 1px dashed rgba(255,255,255,0.08); padding-bottom: 4px;
        }
        .info-row .value { font-weight: 700; color: #fff; }
        .total-income { font-size: 1.8rem; font-weight: 900; margin-top: 6px; text-align: center; letter-spacing: 1px; }
        .left .total-income { color: #fff; text-shadow: 0 0 20px rgba(74,144,196,0.6); }
        .right .total-income { color: #fff; text-shadow: 0 0 20px rgba(232,131,58,0.6); }
        .total-label { text-align: center; font-size: 0.65rem; color: #888; margin-top: -6px; }
        .diff-banner {
            text-align: center; font-weight: 800; font-size: 0.9rem; background: rgba(0,0,0,0.55);
            border-radius: 30px; padding: 6px 22px; backdrop-filter: blur(15px); transition: 0.3s;
        }
        .diff-banner.positive { color: #4caf84; border: 1px solid #4caf8460; }
        .diff-banner.negative { color: #ff5252; border: 1px solid #ff525260; }
        .tables-row { display: flex; gap: 20px; width: 100%; justify-content: center; flex-wrap: wrap; margin-top: 5px; pointer-events: auto; }
        .threshold-table {
            background: rgba(0,0,0,0.5); backdrop-filter: blur(20px); border-radius: 18px;
            padding: 12px 14px; font-size: 0.7rem; color: #ccc; border: 1px solid rgba(255,255,255,0.1);
            flex: 1; min-width: 240px; max-width: 480px;
        }
        .threshold-table h4 { font-size: 0.75rem; letter-spacing: 1px; margin-bottom: 8px; text-transform: uppercase; }
        .left-table h4 { color: #7ab0e0; } .right-table h4 { color: #f0a070; }
        .threshold-table table { width: 100%; border-collapse: collapse; }
        .threshold-table th, .threshold-table td { padding: 5px 6px; border-bottom: 1px solid rgba(255,255,255,0.05); text-align: left; }
        .threshold-table th { color: #aaa; font-weight: 600; }
        .highlight-tier { font-weight: 700; color: #ffd966; }
        @media (max-width: 850px) {
            .cards-row, .tables-row { flex-direction: column; align-items: center; }
            .policy-card, .threshold-table { max-width: 100%; min-width: 90%; }
        }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <div class="badge">📊 STREAMER POLICY COMPARISON</div>
        <h1>Old Policy vs New Policy (Game Revenue Commission)</h1>
    </div>
    <div class="revenue-selector">
        <label>🎮 ROOM GAME FLOW</label>
        <span class="revenue-amount" id="revenueDisplay">80.00</span><span class="revenue-unit">M</span>
        <input type="range" class="revenue-slider" id="revenueSlider" min="4" max="100" value="80" step="0.01">
        <span style="font-size:0.75rem; color:#888;">(4.00M – 100.00M)</span>
    </div>
    <div class="stage" id="stage">
        <canvas id="mainCanvas"></canvas>
        <div class="overlay">
            <div class="cards-row">
                <div class="policy-card left" id="oldCard">
                    <div class="policy-title">📜 I. OLD POLICY</div>
                    <div class="tier-badge" id="oldTierBadge">TIER A</div>
                    <div class="info-row"><span>Base Salary</span><span class="value" id="oldBase">5,000</span></div>
                    <div class="info-row"><span>Commission Rate</span><span class="value" id="oldRate">2.0%</span></div>
                    <div class="info-row"><span>Commission Amount</span><span class="value" id="oldCommission">9,600</span></div>
                    <div class="total-income" id="oldTotal">14,600</div>
                    <div class="total-label">TOTAL SALARY (PHP)</div>
                </div>
                <div class="policy-card right" id="newCard">
                    <div class="policy-title">✨ II. NEW POLICY</div>
                    <div class="tier-badge" id="newTierBadge">TIER A</div>
                    <div class="info-row"><span>Base Salary</span><span class="value" id="newBase">5,000</span></div>
                    <div class="info-row"><span>Commission Rate</span><span class="value" id="newRate">3.5%</span></div>
                    <div class="info-row"><span>Commission Amount</span><span class="value" id="newCommission">16,800</span></div>
                    <div class="total-income" id="newTotal">21,800</div>
                    <div class="total-label">TOTAL SALARY (PHP)</div>
                </div>
            </div>
            <div class="diff-banner positive" id="diffBanner">✨ NEW POLICY ADVANTAGE +7,200</div>
        </div>
    </div>
    <div class="tables-row">
        <div class="threshold-table left-table">
            <h4>📋 OLD POLICY · TIER THRESHOLDS & RATES</h4>
            <table>
                <thead><tr><th>Tier</th><th>Game Flow (M)</th><th>Base Salary</th><th>Rate</th></tr></thead>
                <tbody>
                    <tr><td>E</td><td>10 – 18</td><td>500</td><td>2.0%</td></tr>
                    <tr><td>D</td><td>18 – 35</td><td>1,000</td><td>2.0%</td></tr>
                    <tr><td>C</td><td>35 – 52</td><td>2,000</td><td>2.0%</td></tr>
                    <tr><td>B</td><td>52 – 80</td><td>3,000</td><td>2.0%</td></tr>
                    <tr><td>A</td><td>≥ 80</td><td>5,000</td><td>2.0%</td></tr>
                </tbody>
            </table>
        </div>
        <div class="threshold-table right-table">
            <h4>📋 NEW POLICY · TIER THRESHOLDS & RATES</h4>
            <table>
                <thead><tr><th>Tier</th><th>Game Flow (M)</th><th>Base Salary</th><th>Rate</th></tr></thead>
                <tbody>
                    <tr><td>E</td><td>4 – 8</td><td>500</td><td>2.0%</td></tr>
                    <tr><td>D</td><td>8 – 18</td><td>1,000</td><td>2.0%</td></tr>
                    <tr><td>C</td><td>18 – 35</td><td>2,000</td><td>2.5%</td></tr>
                    <tr><td>B</td><td>35 – 80</td><td>3,000</td><td>3.0%</td></tr>
                    <tr><td>A</td><td>≥ 80</td><td>5,000</td><td>3.5%</td></tr>
                </tbody>
            </table>
        </div>
    </div>
    <div style="text-align:center; font-size:0.65rem; color:#555; margin-top:4px;">
        Commission = Flow (M) × Rate% × 6000 · Drag slider to compare
    </div>
</div>

<script>
    (function() {
        const BASE_SALARY = { A: 5000, B: 3000, C: 2000, D: 1000, E: 500 };

        // Old policy tiers (correct)
        const oldTiers = [
            { name: 'E', min: 10, max: 18, rate: 2.0 },
            { name: 'D', min: 18, max: 35, rate: 2.0 },
            { name: 'C', min: 35, max: 52, rate: 2.0 },
            { name: 'B', min: 52, max: 80, rate: 2.0 },
            { name: 'A', min: 80, max: Infinity, rate: 2.0 }
        ];

        const newTiers = [
            { name: 'E', min: 4, max: 8, rate: 2.0 },
            { name: 'D', min: 8, max: 18, rate: 2.0 },
            { name: 'C', min: 18, max: 35, rate: 2.5 },
            { name: 'B', min: 35, max: 80, rate: 3.0 },
            { name: 'A', min: 80, max: Infinity, rate: 3.5 }
        ];

        function getTier(flowM, tierList) {
            for (let t of tierList) if (flowM >= t.min && flowM < t.max) return t;
            return tierList[tierList.length - 1];
        }

        function calcCommission(flowM, ratePercent) {
            return Math.round(flowM * ratePercent * 60);
        }

        const slider = document.getElementById('revenueSlider');
        const revenueDisplay = document.getElementById('revenueDisplay');
        const oldTierBadge = document.getElementById('oldTierBadge');
        const newTierBadge = document.getElementById('newTierBadge');
        const oldBaseEl = document.getElementById('oldBase');
        const newBaseEl = document.getElementById('newBase');
        const oldRateEl = document.getElementById('oldRate');
        const newRateEl = document.getElementById('newRate');
        const oldCommissionEl = document.getElementById('oldCommission');
        const newCommissionEl = document.getElementById('newCommission');
        const oldTotalEl = document.getElementById('oldTotal');
        const newTotalEl = document.getElementById('newTotal');
        const diffBanner = document.getElementById('diffBanner');
        const oldCard = document.getElementById('oldCard');
        const newCard = document.getElementById('newCard');

        const canvas = document.getElementById('mainCanvas');
        const ctx = canvas.getContext('2d');
        const stage = document.getElementById('stage');
        let W, H, dpr, particles = [];
        const MAX_PARTICLES = 130;

        function resizeCanvas() {
            const rect = stage.getBoundingClientRect();
            dpr = Math.min(window.devicePixelRatio || 1, 2);
            W = rect.width; H = rect.height;
            canvas.width = W * dpr; canvas.height = H * dpr;
            canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
            ctx.setTransform(1, 0, 0, 1, 0, 0);
            ctx.scale(dpr, dpr);
        }

        class Particle {
            constructor(x, y, targetX, targetY, color) {
                this.x = x; this.y = y; this.targetX = targetX; this.targetY = targetY;
                this.color = color; this.progress = 0; this.speed = 0.007 + Math.random() * 0.02;
                this.size = 3 + Math.random() * 7; this.wobble = Math.random() * Math.PI * 2; this.alive = true;
            }
            update() {
                this.progress += this.speed;
                if (this.progress >= 1.0) { this.alive = false; return; }
                const t = this.progress;
                const midX = (this.x + this.targetX) / 2 + Math.sin(t * 8 + this.wobble) * 22;
                const midY = (this.y + this.targetY) / 2 - 45 * Math.sin(t * Math.PI);
                this.x = (1-t)*(1-t)*this.x + 2*(1-t)*t*midX + t*t*this.targetX;
                this.y = (1-t)*(1-t)*this.y + 2*(1-t)*t*midY + t*t*this.targetY;
            }
            draw(ctx) {
                const alpha = 0.75 * (1 - Math.abs(this.progress-0.5)*1.2);
                ctx.fillStyle = this.color.replace('1)', `${alpha})`).replace('0.9', alpha);
                ctx.beginPath(); ctx.arc(this.x, this.y, this.size, 0, 2*Math.PI); ctx.fill();
            }
        }

        function spawnParticles(sx, sy, lx, ly, rx, ry, bias) {
            for (let i=0; i<2; i++) {
                const goRight = Math.random() < bias;
                const tx = goRight ? rx : lx, ty = goRight ? ry : ly;
                const color = goRight ? 'rgba(255,160,80,1)' : 'rgba(100,180,255,1)';
                particles.push(new Particle(sx, sy, tx, ty, color));
            }
            while (particles.length > MAX_PARTICLES) particles.shift();
        }

        function render(ts) {
            ctx.clearRect(0, 0, W, H);
            const sx = W/2, sy = H*0.13, lx = W*0.26, ly = H*0.78, rx = W*0.74, ry = H*0.78;
            ctx.strokeStyle = 'rgba(255,255,255,0.06)'; ctx.lineWidth = 2;
            ctx.beginPath(); ctx.moveTo(sx, sy+20); ctx.bezierCurveTo(sx-70, sy+55, lx-30, ly-40, lx, ly-12); ctx.stroke();
            ctx.beginPath(); ctx.moveTo(sx, sy+20); ctx.bezierCurveTo(sx+70, sy+55, rx+30, ry-40, rx, ry-12); ctx.stroke();
            const pulse = 1 + Math.sin(ts/750)*0.1;
            ctx.fillStyle = '#ffd966'; ctx.beginPath(); ctx.arc(sx, sy, 26*pulse, 0, 2*Math.PI); ctx.fill();

            const flowM = parseFloat(slider.value);
            const oldTier = flowM >= 10 ? getTier(flowM, oldTiers) : null;
            const newTier = getTier(flowM, newTiers);
            const oldRate = oldTier ? oldTier.rate : 2.0;
            const oldBase = oldTier ? BASE_SALARY[oldTier.name] : 0;
            const newBase = BASE_SALARY[newTier.name];
            const oldTotal = oldBase + calcCommission(flowM, oldRate);
            const newTotal = newBase + calcCommission(flowM, newTier.rate);
            const diff = newTotal - oldTotal;
            const biasRight = 0.5 + Math.min(0.45, Math.max(-0.45, diff / 15000 * 0.5));
            spawnParticles(sx, sy, lx, ly, rx, ry, biasRight);

            for (let i=particles.length-1; i>=0; i--) { particles[i].update(); if (!particles[i].alive) particles.splice(i,1); else particles[i].draw(ctx); }
            [{x: lx, y: ly, color: 'rgba(74,144,196,0.25)'}, {x: rx, y: ry, color: 'rgba(232,131,58,0.25)'}].forEach(c => {
                ctx.fillStyle = c.color; ctx.beginPath(); ctx.arc(c.x, c.y, 28, 0, 2*Math.PI); ctx.fill();
            });
            requestAnimationFrame(render);
        }

        function updateUI() {
            const flowM = parseFloat(slider.value);
            revenueDisplay.textContent = flowM.toFixed(2);
            const oldTier = flowM >= 10 ? getTier(flowM, oldTiers) : null;
            const newTier = getTier(flowM, newTiers);
            if (oldTier) {
                oldTierBadge.textContent = `TIER ${oldTier.name}`; oldTierBadge.classList.remove('no-tier');
                oldBaseEl.textContent = BASE_SALARY[oldTier.name].toLocaleString();
                oldRateEl.textContent = oldTier.rate.toFixed(1)+'%';
            } else {
                oldTierBadge.textContent = 'NO TIER (Commission Only)'; oldTierBadge.classList.add('no-tier');
                oldBaseEl.textContent = '0'; oldRateEl.textContent = '2.0%';
            }
            newTierBadge.textContent = `TIER ${newTier.name}`;
            newBaseEl.textContent = BASE_SALARY[newTier.name].toLocaleString();
            newRateEl.textContent = newTier.rate.toFixed(1)+'%';

            const oldRate = oldTier ? oldTier.rate : 2.0;
            const oldComm = calcCommission(flowM, oldRate);
            const newComm = calcCommission(flowM, newTier.rate);
            oldCommissionEl.textContent = oldComm.toLocaleString();
            newCommissionEl.textContent = newComm.toLocaleString();

            const oldBase = oldTier ? BASE_SALARY[oldTier.name] : 0;
            const newBase = BASE_SALARY[newTier.name];
            const oldTotal = oldBase + oldComm;
            const newTotal = newBase + newComm;
            oldTotalEl.textContent = oldTotal.toLocaleString();
            newTotalEl.textContent = newTotal.toLocaleString();

            const diff = newTotal - oldTotal;
            if (diff > 0) {
                diffBanner.textContent = `✨ NEW POLICY ADVANTAGE +${diff.toLocaleString()}`;
                diffBanner.className = 'diff-banner positive';
                newCard.style.boxShadow = '0 0 35px rgba(232,131,58,0.35)'; oldCard.style.boxShadow = 'none';
            } else if (diff < 0) {
                diffBanner.textContent = `📜 OLD POLICY ADVANTAGE +${Math.abs(diff).toLocaleString()}`;
                diffBanner.className = 'diff-banner negative';
                oldCard.style.boxShadow = '0 0 35px rgba(74,144,196,0.35)'; newCard.style.boxShadow = 'none';
            } else {
                diffBanner.textContent = '⚖️ EQUAL INCOME'; diffBanner.className = 'diff-banner';
                oldCard.style.boxShadow = 'none'; newCard.style.boxShadow = 'none';
            }

            document.querySelectorAll('.highlight-tier').forEach(el => el.classList.remove('highlight-tier'));
            if (oldTier) {
                const rows = document.querySelectorAll('.left-table tbody tr');
                const idx = oldTiers.findIndex(t => t.name === oldTier.name);
                if (idx >= 0) rows[idx].querySelectorAll('td').forEach(td => td.classList.add('highlight-tier'));
            }
            const nRows = document.querySelectorAll('.right-table tbody tr');
            const nIdx = newTiers.findIndex(t => t.name === newTier.name);
            if (nIdx >= 0) nRows[nIdx].querySelectorAll('td').forEach(td => td.classList.add('highlight-tier'));
        }

        slider.addEventListener('input', updateUI);
        window.addEventListener('resize', () => { resizeCanvas(); particles = []; });
        resizeCanvas(); updateUI(); requestAnimationFrame(render);
    })();
</script>
</body>
</html>
